# LuckyTwo Environment Variables

# App URL (required for crypto payment webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Toman to USD conversion rate (default: 50000)
TOMAN_PER_USD=50000

# NOWPayments (optional — without these, mock mode is used for testing)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
